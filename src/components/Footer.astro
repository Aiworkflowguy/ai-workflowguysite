---
import { site, nav } from '../config/site';
const year = new Date().getFullYear();
---
<footer class="ftr">
  <div class="container">
    <div class="ftr__top">
      <div class="ftr__brand">
        <div class="hdr-mark" aria-hidden="true"></div>
        <p class="ftr__name">AI Workflow Guy</p>
        <p class="faint" style="margin-top:.4rem">AI consulting for local businesses · {site.region}</p>
        <a href={site.demoPhoneHref} class="ftr__demo">
          <span class="faint mono" style="font-size:.7rem;letter-spacing:.12em;text-transform:uppercase">Hear the receptionist live</span>
          <span class="demo-number">{site.demoPhone}</span>
        </a>
      </div>

      <nav class="ftr__nav" aria-label="Footer">
        {nav.map((item) => <a href={item.href} class="muted">{item.label}</a>)}
        <a href="/contact" class="muted">Book a Demo</a>
      </nav>
    </div>

    <hr class="divider" />

    <div class="ftr__legal">
      <p class="faint">© {year} {site.brand}. All rights reserved.</p>
      <p class="faint">{site.address} · <a href={`mailto:${site.email}`} class="muted">{site.email}</a></p>
    </div>
  </div>
</footer>

<style>
  .ftr { border-top: 1px solid var(--border); padding-block: clamp(2.5rem, 6vw, 4rem) 2rem; background: var(--bg); }
  .ftr__top { display: grid; gap: 2rem; grid-template-columns: 1fr; }
  .ftr__name { font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; margin-top: .6rem; }
  .hdr-mark { width: 20px; height: 20px; border-radius: 6px; background: var(--lime); box-shadow: 0 0 18px -2px var(--lime); }
  .ftr__demo { display: inline-flex; flex-direction: column; gap: .15rem; margin-top: 1rem; }
  .ftr__demo .demo-number { font-size: 1.1rem; }
  .ftr__nav { display: grid; grid-template-columns: 1fr 1fr; gap: .7rem 1.5rem; font-family: var(--font-mono); font-size: .85rem; align-content: start; }
  .ftr__nav a:hover { color: var(--lime); }
  .ftr__legal { display: flex; flex-wrap: wrap; justify-content: space-between; gap: .5rem; margin-top: 1.5rem; font-size: .82rem; }
  @media (min-width: 760px) { .ftr__top { grid-template-columns: 1.4fr 1fr; } }
</style>
