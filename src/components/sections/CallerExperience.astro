---
import { site } from '../../config/site';
// "How it feels to the caller" — a sample exchange so visitors picture the call
// before they dial. Illustrative script, clearly framed as a sample, not a claim.
const turns = [
  { who: 'ai', text: 'Thanks for calling — this is the front desk. How can I help?' },
  { who: 'caller', text: 'Hi, do you have anything open this week? I need to come in.' },
  { who: 'ai', text: 'Absolutely. I can get you in Thursday at 2:00 or Friday at 10:30 — which works better?' },
  { who: 'caller', text: 'Thursday at 2 is perfect.' },
  { who: 'ai', text: 'Done — you’re booked for Thursday at 2:00. I’ll text you a confirmation now. Anything else?' },
];
---
<section class="section calx">
  <div class="container calx__grid">
    <div class="reveal">
      <span class="eyebrow">How it feels to the caller</span>
      <h2 class="h2" style="margin-top:.8rem">A normal conversation — that ends in a booking.</h2>
      <p class="lead" style="margin-top:.9rem">
        No phone-tree menus, no "press 1." The caller talks like they would to a great front-desk person,
        and hangs up with an appointment already on the calendar.
      </p>
      <ul class="calx__points">
        <li>Natural back-and-forth — it listens and responds, it doesn’t read a menu.</li>
        <li>Offers real open times and books the one they pick.</li>
        <li>Confirms by text before the call even ends.</li>
      </ul>
      <a href={site.demoPhoneHref} class="btn btn--primary" style="margin-top:1.6rem">Hear it yourself · {site.demoPhone}</a>
    </div>

    <div class="calx__phone card reveal" aria-label="Sample call — illustrative">
      <div class="calx__bar">
        <span class="calx__dot" aria-hidden="true"></span>
        <span class="mono faint" style="font-size:.72rem;letter-spacing:.12em;text-transform:uppercase">Sample call</span>
      </div>
      <ol class="calx__log">
        {turns.map((t) => (
          <li class={`calx__turn calx__turn--${t.who}`}>
            <span class="calx__label mono">{t.who === 'ai' ? 'AI receptionist' : 'Caller'}</span>
            <p>{t.text}</p>
          </li>
        ))}
      </ol>
      <p class="faint mono calx__note">Illustrative — call the live line above to hear the real thing.</p>
    </div>
  </div>
</section>

<style>
  .calx__grid { display: grid; gap: 2.4rem; grid-template-columns: 1fr; align-items: center; }
  .calx__points { list-style: none; padding: 0; margin: 1.4rem 0 0; display: grid; gap: .7rem; }
  .calx__points li { position: relative; padding-left: 1.5rem; color: var(--muted); }
  .calx__points li::before { content: "→"; position: absolute; left: 0; color: var(--lime); font-family: var(--font-mono); }
  .calx__phone { padding: 1.1rem; }
  .calx__bar { display: flex; align-items: center; gap: .55rem; padding-bottom: .9rem; border-bottom: 1px solid var(--border); margin-bottom: 1rem; }
  .calx__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--lime); box-shadow: 0 0 0 0 var(--lime); animation: calx-pulse 2.4s infinite; }
  .calx__log { list-style: none; padding: 0; margin: 0; display: grid; gap: .8rem; }
  .calx__turn { display: grid; gap: .25rem; }
  .calx__label { font-size: .64rem; letter-spacing: .14em; text-transform: uppercase; color: var(--faint); }
  .calx__turn p { padding: .6rem .85rem; border-radius: var(--radius-sm); max-width: 85%; }
  .calx__turn--ai p { background: var(--lime-dim); border: 1px solid var(--border-lime); color: var(--text); justify-self: start; }
  .calx__turn--caller { justify-items: end; }
  .calx__turn--caller p { background: var(--surface-2); border: 1px solid var(--border); justify-self: end; }
  .calx__turn--caller .calx__label { text-align: right; }
  .calx__note { font-size: .7rem; margin-top: 1rem; text-align: center; }
  @keyframes calx-pulse { 0% { box-shadow: 0 0 0 0 rgba(199,249,75,.5); } 70% { box-shadow: 0 0 0 7px rgba(199,249,75,0); } 100% { box-shadow: 0 0 0 0 rgba(199,249,75,0); } }
  @media (prefers-reduced-motion: reduce) { .calx__dot { animation: none; } }
  @media (min-width: 900px) { .calx__grid { grid-template-columns: 1fr 1fr; } }
</style>
