---
import { site } from '../../config/site';
interface Props {
  eyebrow?: string;
  title?: string;
  sub?: string;
}
const {
  eyebrow = `AI Consultant · ${site.region}`,
  title = 'AI consulting for local businesses — no hype, just systems that pay for themselves.',
  sub = "Most AI advice is vague. Mine ends with a working system. We start with an audit of your operations, pinpoint where automation pays back fastest — usually the calls and bookings you're losing — and I build it for you.",
} = Astro.props;
---
<section class="hero section">
  <div class="container hero__grid">
    <div class="reveal">
      <span class="eyebrow">{eyebrow}</span>
      <h1 class="h1" style="margin-top:1.1rem">{title}</h1>
      <p class="lead" style="margin-top:1.35rem">{sub}</p>

      <div class="hero__actions">
        <a href="/pricing" class="btn btn--primary btn--lg">Book your AI Audit · ${site.pricing.audit}</a>
        <a href={site.demoPhoneHref} class="btn btn--ghost btn--lg">
          <span class="hero__dot" aria-hidden="true"></span> Or call the receptionist: {site.demoPhone}
        </a>
      </div>
    </div>

    <aside class="hero__demo card card--accent reveal" aria-label="Live demo">
      <span class="badge">Live · Try it now</span>
      <p class="h3" style="margin-top:1rem">Call the AI receptionist and talk to it.</p>
      <p class="muted" style="margin-top:.6rem">It answers, holds a real conversation, and books a slot — the exact system I build for your business.</p>
      <a href={site.demoPhoneHref} class="hero__bignum demo-number">{site.demoPhone}</a>
      <p class="faint mono" style="font-size:.72rem;letter-spacing:.1em">30 seconds · no signup</p>
    </aside>
  </div>
</section>

<style>
  .hero { padding-top: clamp(3rem, 7vw, 5.5rem); }
  .hero__grid { display: grid; gap: clamp(2rem, 5vw, 3.5rem); grid-template-columns: 1fr; align-items: center; }
  .hero__actions { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 2rem; }
  .hero__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--lime); }
  .hero__demo { display: flex; flex-direction: column; align-items: flex-start; gap: .3rem; }
  .hero__bignum { font-size: clamp(1.6rem, 4vw, 2.15rem); margin: 1rem 0 .4rem; }
  @media (min-width: 940px) { .hero__grid { grid-template-columns: 1.25fr .9fr; } }
</style>
