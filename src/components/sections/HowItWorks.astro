---
// A real ordered process, so the 01/02/03 markers encode actual sequence.
const steps = [
  {
    n: '01',
    title: 'Audit',
    body: 'I look at where calls, bookings, and follow-ups leak revenue, and hand you a plain-English findings doc with the fixes ranked by payback.',
  },
  {
    n: '02',
    title: 'Build the front office',
    body: 'I build your 24/7 AI receptionist — it answers every call, books appointments live during the call, and texts back missed calls automatically.',
  },
  {
    n: '03',
    title: 'Expand',
    body: 'Once the front office is capturing revenue, we automate the rest — internal ops, lead follow-up, back-office workflows — one system at a time.',
  },
];
---
<section class="section how">
  <div class="container">
    <div class="reveal" style="max-width:60ch">
      <span class="eyebrow">How it works</span>
      <h2 class="h2" style="margin-top:.8rem">One system that pays for itself — then the next.</h2>
    </div>

    <ol class="how__grid">
      {steps.map((s) => (
        <li class="how__step card card--interactive reveal">
          <span class="how__n mono">{s.n}</span>
          <h3 class="h3" style="margin-top:.6rem">{s.title}</h3>
          <p class="muted" style="margin-top:.5rem">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how__grid { list-style: none; padding: 0; margin: 2.2rem 0 0; display: grid; gap: var(--gap); grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); counter-reset: none; }
  .how__step { position: relative; }
  .how__n { color: var(--lime); font-size: .95rem; letter-spacing: .1em; }
</style>
