---
import { site } from '../../config/site';
// PRE-CALL INTAKE — filled out by warm contacts before our call.
// Native Netlify Forms (name="intake"). Detected via the static copies in
// public/__forms.html; keep every field `name` here in sync with that file.
// Required fields are intentionally minimal: email + the biggest-frustration question.
---
<section class="section intake">
  <div class="container intake__wrap">
    <div class="reveal intake__intro">
      <span class="eyebrow">Pre-call intake</span>
      <h1 class="h1" style="margin-top:1rem">Tell me where the time and money are leaking.</h1>
      <p class="lead" style="margin-top:1rem">
        Fill this out before we talk so I show up already knowing your business — where the
        bottlenecks are and what's worth automating. Takes two minutes; only your email and the
        big frustration are required.
      </p>
    </div>

    <form
      class="intake__form card reveal"
      name="intake"
      method="POST"
      action="/thank-you-intake"
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <input type="hidden" name="form-name" value="intake" />
      <p hidden>
        <label>Don't fill this out: <input name="bot-field" /></label>
      </p>

      <label>Name<input type="text" name="name" autocomplete="name" /></label>
      <label>Email *<input type="email" name="email" required autocomplete="email" /></label>
      <label>Business<input type="text" name="business" autocomplete="organization" /></label>
      <label>Phone<input type="tel" name="phone" autocomplete="tel" /></label>
      <label>What's the biggest frustration or bottleneck in your business right now? *
        <textarea name="biggest_frustration" rows="4" required></textarea>
      </label>
      <label>If one task could just run itself, what would it be?
        <textarea name="wish_automated" rows="3"></textarea>
      </label>

      <button type="submit" class="btn btn--primary btn--lg" style="width:100%">Send it over</button>
      <p class="faint mono" style="font-size:.72rem;text-align:center">Thanks for doing this before we talk.</p>
    </form>
  </div>
</section>

<style>
  .intake__wrap { max-width: 640px; margin-inline: auto; }
  .intake__intro { text-align: center; }
  .intake__intro .lead { margin-inline: auto; }
  .intake__form { display: grid; gap: .9rem; margin-top: 2rem; }
  .intake__form label { display: grid; gap: .35rem; font-family: var(--font-mono); font-size: .78rem; letter-spacing: .04em; color: var(--muted); }
  .intake__form input, .intake__form textarea {
    font-family: var(--font-body); font-size: 1rem; color: var(--text);
    background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: .75rem .85rem;
  }
  .intake__form textarea { resize: vertical; }
  .intake__form input:focus, .intake__form textarea:focus { outline: 2px solid var(--lime); outline-offset: 1px; border-color: transparent; }
</style>
