---
// PROOF RULE (hard): never fabricate testimonials, client logos, or stats.
// The Peak Mode angle below is Peter's OWN business — legitimate founder proof.
// Client results render from site.clientResults and stay hidden until real ones
// exist (see src/config/site.ts) — so the live site never shows placeholders.
import { clientResults } from '../../config/site';
---
<section class="section proof">
  <div class="container">
    <div class="reveal" style="max-width:62ch">
      <span class="eyebrow">Proof</span>
      <h2 class="h2" style="margin-top:.8rem">I don't just advise on automation — I run a business on it.</h2>
      <p class="lead" style="margin-top:.9rem">
        I built and automated an entire e-commerce brand, Peak Mode Supplements, on the same stack I build for clients —
        an AI-driven system handling fulfillment, support, marketing, and reporting.
      </p>
    </div>

    <!-- Founder proof: Peter's own business. Real, not a client claim. -->
    <div class="card card--accent reveal" style="margin-top:2rem">
      <span class="badge">Founder-built</span>
      <p class="h3" style="margin-top:.8rem">A full brand, run by AI workflows I built myself.</p>
      <p class="muted" style="margin-top:.6rem;max-width:62ch">
        The point isn't a slide deck — it's that the person building your systems already operates one at scale.
        On your audit call I'll walk you through it live.
      </p>
      <a href="/proof" class="btn btn--ghost" style="margin-top:1.2rem">See how it's built</a>
    </div>

    {/* Client results — only shown once real, permissioned results exist. */}
    {clientResults.length > 0 && (
      <div class="grid grid--3 reveal" style="margin-top:var(--gap)">
        {clientResults.map((c) => (
          <article class="card">
            <p style="margin-top:.2rem">{c.result}</p>
            <p class="faint mono" style="margin-top:.9rem;font-size:.72rem">{c.attribution}</p>
          </article>
        ))}
      </div>
    )}
  </div>
</section>
