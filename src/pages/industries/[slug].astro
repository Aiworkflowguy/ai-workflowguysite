---
// PER-VERTICAL PAGE — one template, every industry page built from the config.
// Add a vertical to src/config/industries.ts and its page appears here.
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuditCta from '../../components/sections/AuditCta.astro';
import { site } from '../../config/site';
import { industries, type Vertical } from '../../config/industries';
import { serviceSchema, breadcrumbSchema } from '../../config/schema';
import { publicImage } from '../../lib/asset';

export function getStaticPaths() {
  return industries.map((v) => ({ params: { slug: v.slug }, props: { v } }));
}

interface Props { v: Vertical }
const { v } = Astro.props;

// Auto-appears once `npm run images` has generated it; null (and hidden) until then.
const heroImg = publicImage(`/images/industry-${v.slug}.webp`);
---
<BaseLayout
  title={`AI receptionist for ${v.name} | AI Workflow Guy`}
  description={`${v.headline} A 24/7 AI receptionist that answers, books, and texts back missed calls — built for ${v.name.toLowerCase()}. Hear it live: ${site.demoPhone}.`}
  schema={[
    serviceSchema({
      name: `AI receptionist for ${v.name.toLowerCase()}`,
      description: `${v.intro} ${v.outcome}`,
      serviceType: 'AI phone answering and appointment booking',
      url: `/industries/${v.slug}`,
    }),
    breadcrumbSchema([
      { name: 'Home', path: '/' },
      { name: 'Industries', path: '/industries' },
      { name: v.short, path: `/industries/${v.slug}` },
    ]),
  ]}
>
  <!-- Vertical hero -->
  <section class="section vhero">
    <div class="container vhero__grid">
      <div class="reveal">
        <span class="eyebrow">{v.eyebrow}</span>
        <h1 class="h1" style="margin-top:1.1rem">{v.headline}</h1>
        <p class="lead" style="margin-top:1.35rem">{v.intro}</p>
        <div class="vhero__actions">
          <a href={site.calendly} class="btn btn--primary btn--lg">Book your AI Audit · ${site.pricing.audit}</a>
          <a href={site.demoPhoneHref} class="btn btn--ghost btn--lg">
            <span class="vhero__dot" aria-hidden="true"></span> Hear it live: {site.demoPhone}
          </a>
        </div>
      </div>

      <aside class="card card--accent reveal vhero__demo" aria-label="Live demo">
        <span class="badge">Live · Try it now</span>
        <p class="h3" style="margin-top:1rem">Call it and pretend you’re a customer.</p>
        <p class="muted" style="margin-top:.6rem">Same receptionist we’d build for your business — answering and booking in real time.</p>
        <a href={site.demoPhoneHref} class="vhero__num demo-number">{site.demoPhone}</a>
        <p class="faint mono" style="font-size:.72rem;letter-spacing:.1em">30 seconds · no signup</p>
      </aside>
    </div>
  </section>

  {heroImg && (
    <section class="container vbanner reveal">
      <img
        src={heroImg}
        alt={`A ${v.name.toLowerCase()} setting — the kind of business the AI receptionist answers for.`}
        width="1280"
        height="720"
        loading="lazy"
        decoding="async"
        class="vbanner__img"
      />
    </section>
  )}

  <hr class="divider" />

  <!-- Where the calls leak -->
  <section class="section">
    <div class="container">
      <div class="reveal" style="max-width:60ch">
        <span class="eyebrow">Where the calls leak</span>
        <h2 class="h2" style="margin-top:.8rem">Sound familiar?</h2>
      </div>
      <div class="grid grid--3" style="margin-top:2rem">
        {v.pains.map((p) => (
          <article class="card reveal">
            <span class="mono" style="color:var(--lime)" aria-hidden="true">✕</span>
            <p class="muted" style="margin-top:.6rem">{p}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- What the receptionist does for this vertical -->
  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="reveal" style="max-width:60ch">
        <span class="eyebrow">What it does for you</span>
        <h2 class="h2" style="margin-top:.8rem">Every call answered. Every booking captured.</h2>
      </div>
      <div class="grid grid--3" style="margin-top:2rem">
        {v.handles.map((h, i) => (
          <article class="card card--interactive reveal">
            <span class="mono" style="color:var(--lime);font-size:.95rem;letter-spacing:.1em">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="h3" style="margin-top:.6rem">{h.title}</h3>
            <p class="muted" style="margin-top:.5rem">{h.body}</p>
          </article>
        ))}
      </div>
      <div class="card card--accent reveal" style="margin-top:var(--gap);text-align:center">
        <p class="h3">{v.outcome}</p>
      </div>
    </div>
  </section>

  <AuditCta />
</BaseLayout>

<style>
  .vhero { padding-top: clamp(2.5rem, 6vw, 4rem); }
  .vhero__grid { display: grid; gap: clamp(2rem, 5vw, 3.5rem); grid-template-columns: 1fr; align-items: center; }
  .vhero__actions { display: flex; flex-wrap: wrap; gap: .8rem; margin-top: 2rem; }
  .vhero__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--lime); }
  .vhero__demo { display: flex; flex-direction: column; align-items: flex-start; gap: .3rem; }
  .vhero__num { font-size: clamp(1.6rem, 4vw, 2.15rem); margin: 1rem 0 .4rem; }
  @media (min-width: 940px) { .vhero__grid { grid-template-columns: 1.25fr .9fr; } }

  /* Generated industry banner (npm run images). Framed to match cards; the
     inset lime border + gradient tie it into the dark theme. */
  .vbanner { margin-block: clamp(1rem, 3vw, 1.75rem); }
  .vbanner__img {
    width: 100%; aspect-ratio: 16 / 9; object-fit: cover;
    border-radius: var(--radius); border: 1px solid var(--border);
    box-shadow: 0 0 0 1px var(--border-lime), 0 30px 80px -40px var(--lime-dim);
  }
</style>
