---
// Confirmation for the CONTACT form (action="/thank-you"). Consultant-toned.
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../config/site';
---
<BaseLayout title="Thanks — AI Workflow Guy" description="Thanks for reaching out.">
  <section class="section thanks">
    <div class="container thanks__inner">
      <span class="eyebrow" style="justify-content:center">Got it</span>
      <h1 class="h1" style="margin-top:1rem">Thanks — I'll be in touch.</h1>
      <p class="lead" style="margin:1.1rem auto 0">Usually same day.</p>
      <p class="thanks__aside faint" style="margin:1.6rem auto 0">
        In the meantime, if you want to hear one example of what I build, call
        <a href={site.demoPhoneHref} class="demo-number">{site.demoPhone}</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks { min-height: 60vh; display: grid; place-items: center; text-align: center; }
  .thanks__inner { max-width: 56ch; }
  .thanks__aside { font-size: .92rem; }
  .thanks__aside .demo-number { font-size: .95rem; }
</style>
